{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true, // ✅ needs noEmit OR emitDeclarationOnly
    "resolveJsonModule": true,
    "isolatedModules": true,

    "noEmit": true, // ✅ keep this — satisfies allowImportingTsExtensions
    "composite": true, // ✅ add this — satisfies project references

    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "api/og"]
}
