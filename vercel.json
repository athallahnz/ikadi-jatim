{
  "rewrites": [
    {
      "source": "/kabar/daerah/:daerah/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Twitterbot|WhatsApp|Slackbot|Discordbot|LinkedInBot).*"
        }
      ],
      "destination": "https://adutxuaoypeddcstmyvw.supabase.co/functions/v1/render-meta?slug=:slug&type=event"
    },
    {
      "source": "/kajian/:scope/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Twitterbot|WhatsApp|Slackbot|Discordbot|LinkedInBot).*"
        }
      ],
      "destination": "https://adutxuaoypeddcstmyvw.supabase.co/functions/v1/render-meta?slug=:slug&type=article"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
