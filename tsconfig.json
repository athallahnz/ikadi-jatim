{
  "files": [],
  "compilerOptions": {
    /* Menghilangkan Warning BaseUrl */
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",

    /* Path Mapping */
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Fix Error Emit pada Referenced Project */
    "noEmit": true,
    "composite": false,

    /* Standard Modern React/Vite */
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "module": "ESNext",
    "moduleResolution": "Bundler"
  },
  "include": ["src", "server", "types", "scripts"],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ]
}
